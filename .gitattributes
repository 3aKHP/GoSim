# Git LFS - Track large binary files
# AI engine executables
*.exe filter=lfs diff=lfs merge=lfs -text

# Windows DLLs
*.dll filter=lfs diff=lfs merge=lfs -text

# Model files
*.bin.gz filter=lfs diff=lfs merge=lfs -text

# Pachi data files
*.dat filter=lfs diff=lfs merge=lfs -text
*.gamma filter=lfs diff=lfs merge=lfs -text
*.spat filter=lfs diff=lfs merge=lfs -text

# Certificate files
*.pem filter=lfs diff=lfs merge=lfs -text

# Normalize line endings for text files
* text=auto
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.js text eol=lf
*.cfg text eol=lf

# Exclude internal documents from git archive exports
docs/design/ export-ignore
docs/dev/ export-ignore
docs/PROJECT_STATUS.md export-ignore
debug/ export-ignore
